{
  "name": "mini-dify",
  "private": true,
  "version": "0.1.0",
  "description": "Mini version of Dify - visual LLM workflow builder",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev:backend": "pnpm --filter @mini-dify/backend dev",
    "dev:frontend": "pnpm --filter @mini-dify/frontend dev",
    "dev": "pnpm run --parallel dev:backend dev:frontend",
    "build:shared": "pnpm --filter @mini-dify/shared build",
    "build:backend": "pnpm --filter @mini-dify/backend build",
    "build:frontend": "pnpm --filter @mini-dify/frontend build",
    "build": "pnpm build:shared && pnpm build:backend && pnpm build:frontend",
    "typecheck": "pnpm --filter @mini-dify/shared type-check && pnpm --filter @mini-dify/backend type-check && pnpm --filter @mini-dify/frontend type-check",
    "test": "pnpm --filter @mini-dify/backend exec node --import tsx --test src/core/nodes/*.spec.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4"
  }
}
